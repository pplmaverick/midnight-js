dotenv_if_exists

#run 'yarn clean' after updating this version, to trigger recompilation after updating the version with 'yarn build'
export COMPACTC_VERSION=0.31.0 # must be set to a valid version of compactc
export COMPACT_TAG_PREFIX=compactc-v # override default value
export COMPACT_REPO=midnightntwrk/compact # override default value

export NODE_VERSION_PREFIX=v
export NODE_VERSIONS=~/.nvm/versions/node
use node 22

# Select Midnight environment for testkit docker images.
# Fail-fast on typos rather than silently loading nothing and producing
# confusing 'image: ghcr.io/.../proof-server:' (empty tag) errors later.
export TESTKIT_DOCKER_ENV="${TESTKIT_DOCKER_ENV:-preprod}"
case "$TESTKIT_DOCKER_ENV" in
  qanet|preview|preprod|mainnet|devnet) ;;
  *) echo "ERROR: TESTKIT_DOCKER_ENV must be one of qanet|preview|preprod|mainnet|devnet (got: '$TESTKIT_DOCKER_ENV')" >&2; exit 1 ;;
esac
dotenv "testkit-js/env/${TESTKIT_DOCKER_ENV}.env"

# point out to users at commit time that commits need to be signed,
# not once they've done many commits and are trying to push a PR:
git config --local commit.gpgSign true
git config --local tag.gpgSign true

echo
echo "Set COMPACTC_VERSION=$COMPACTC_VERSION"
echo "Using Node $(node -v) from $(which node)"
echo "TESTKIT_DOCKER_ENV=$TESTKIT_DOCKER_ENV (proof-server=$PROOF_SERVER_VERSION, indexer=$INDEXER_VERSION, midnight-node=$MIDNIGHT_NODE_VERSION)"
