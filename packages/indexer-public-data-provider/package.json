{
  "name": "@midnight-ntwrk/midnight-js-indexer-public-data-provider",
  "version": "5.0.0-beta.4",
  "description": "Implementation of public data provider based on the Midnight Pub-sub indexer",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "repository": "git@github.com:midnight-ntwrk/artifacts",
  "packageManager": "yarn@4.14.1",
  "author": "IOHK",
  "license": "Apache-2.0",
  "scripts": {
    "gen": "rm -rf gen && graphql-codegen",
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo .rollup.cache",
    "build": "rollup -c rollup.config.mjs",
    "test": "vitest run",
    "deploy": "yarn npm publish --tolerate-republish"
  },
  "dependencies": {
    "@apollo/client": "^4.2.3",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@midnight-ntwrk/midnight-js-network-id": "workspace:*",
    "@midnight-ntwrk/midnight-js-protocol": "workspace:*",
    "@midnight-ntwrk/midnight-js-types": "workspace:*",
    "@midnight-ntwrk/midnight-js-utils": "workspace:*",
    "buffer": "^6.0.3",
    "cross-fetch": "^4.1.0",
    "graphql": "^17.0.1",
    "graphql-ws": "^6.0.8",
    "isomorphic-ws": "^5.0.0",
    "rxjs": "^7.8.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/client-preset": "^6.0.1",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^6.0.5",
    "@types/ws": "^8.18.1",
    "vitest": "^4.1.7"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=22"
  }
}
